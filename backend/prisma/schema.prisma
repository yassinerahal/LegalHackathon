generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  username          String
  full_name         String
  email             String              @unique
  password_hash     String
  role              String              @default("pending")
  is_approved       Boolean             @default(false)
  client_id         Int?                @unique
  created_at        DateTime            @default(now())
  client            Client?             @relation(fields: [client_id], references: [id], onDelete: Cascade)
  owned_cases       Case[]
  case_assignments  CaseAssignment[]
  uploaded_versions DocumentVersion[]   @relation("UploadedByUser")

  @@map("users")
}

model Client {
  id                 Int                 @id @default(autoincrement())
  full_name          String
  email              String?
  phone              String?
  address            String?
  zip_code           String?
  city               String?
  state              String?
  created_at         DateTime            @default(now())
  users              User[]
  cases              Case[]
  remote_access_keys RemoteAccessToken[]

  @@map("clients")
}

model RemoteAccessToken {
  id          Int      @id @default(autoincrement())
  client_id   Int
  token_hash  String   @unique
  status      String   @default("active")
  expires_at  DateTime
  used_at     DateTime?
  created_at  DateTime @default(now())
  client      Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("remote_access_tokens")
}

model Case {
  id                 Int               @id @default(autoincrement())
  name               String
  client_id          Int
  owner_id           Int?
  status             String            @default("open")
  deadline           DateTime?
  short_description  String?
  created_at         DateTime          @default(now())
  client             Client            @relation(fields: [client_id], references: [id], onDelete: Cascade)
  owner              User?             @relation(fields: [owner_id], references: [id], onDelete: SetNull)
  case_assignments   CaseAssignment[]
  documents          Document[]
  case_placeholders  CasePlaceholder[]

  @@map("cases")
}

model CaseAssignment {
  id         Int      @id @default(autoincrement())
  case_id    Int
  user_id    Int
  created_at DateTime @default(now())
  case       Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([case_id, user_id])
  @@map("case_assignments")
}

model Document {
  id                Int               @id @default(autoincrement())
  case_id           Int
  name              String
  created_at        DateTime          @default(now())
  case              Case              @relation(fields: [case_id], references: [id], onDelete: Cascade)
  document_versions DocumentVersion[]

  @@map("documents")
}

model DocumentVersion {
  id             Int       @id @default(autoincrement())
  document_id    Int
  original_name  String
  s3_key         String    @unique
  mime_type      String?
  encryption_iv  String?
  encryption_tag String?
  uploaded_at    DateTime  @default(now())
  uploaded_by    Int?
  document       Document  @relation(fields: [document_id], references: [id], onDelete: Cascade)
  uploaded_user  User?     @relation("UploadedByUser", fields: [uploaded_by], references: [id], onDelete: SetNull)

  @@map("document_versions")
}

model CasePlaceholder {
  id              Int      @id @default(autoincrement())
  case_id         Int
  name            String
  status          String   @default("Pending")
  attached_files  Json     @default("[]")
  created_at      DateTime @default(now())
  case            Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@map("case_placeholders")
}
