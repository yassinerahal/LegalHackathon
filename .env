# ---------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# ---------------------------------------------------------
# These credentials will be used by Docker to setup the DB
# and by your Node.js backend to connect to it.
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=nextact-db

# ---------------------------------------------------------
# STORAGE CONFIGURATION (MinIO)
# ---------------------------------------------------------
# Access keys for your local S3-compatible cloud storage.
MINIO_USER=admin
MINIO_PASSWORD=NextAct-

# ---------------------------------------------------------
# BACKEND SERVER CONFIGURATION
# ---------------------------------------------------------
# The port your Node.js Express server will listen on
PORT=3000

# Secret key for signing JSON Web Tokens (JWT) during user login.
# Make sure this is very long and random in production!
JWT_SECRET=YourExtremelyLongAndRandomSecretKeyGoesHere!

# Defines the environment (development, test, or production)
NODE_ENV=development