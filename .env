# ---------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# ---------------------------------------------------------
# These credentials will be used by Docker to setup the DB
# and by your Node.js backend to connect to it.
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=nextact-db

# ---------------------------------------------------------
# LOCALSTACK S3 CONFIGURATION
# ---------------------------------------------------------
# AWS SDK will automatically look for these exact variable names
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# The name of your bucket
S3_BUCKET_NAME=legal-documents

# ---------------------------------------------------------
# BACKEND SERVER CONFIGURATION
# ---------------------------------------------------------
# The port your Node.js Express server will listen on
PORT=3000

# Secret key for signing JSON Web Tokens (JWT) during user login.
# Make sure this is very long and random in production!
JWT_SECRET=YourExtremelyLongAndRandomSecretKeyGoesHere!

# Defines the environment (development, test, or production)
NODE_ENV=development


# ---------------------------------------------------------
# MINIO CONFIGURATION
# ---------------------------------------------------------
# The name of the bucket you just created
MINIO_BUCKET_NAME=legal-documents

# Just use your admin login as the keys for local development!
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=NextAct-