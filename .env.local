# =========================================================
# LOCAL ENVIRONMENT CONFIGURATION
# =========================================================
# This file is used for local development with a bundler (Vite, Webpack, etc.)
# For vanilla JS without a bundler, the config.js module uses other mechanisms
#
# Vite-based bundlers read this file automatically
# For other build tools, you may need to configure environment variable loading
#
# LOCAL DEVELOPMENT (Default Backend on Port 3000)
# This is the standard local setup where:
# - Frontend is served on http://localhost:5500 (Live Server) or http://localhost:3000 (Vite dev server)
# - Backend API is on http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api

# ALTERNATIVE: Remote Backend Development
# If your backend is running on a different machine or port, uncomment and modify:
# VITE_API_URL=http://192.168.1.100:3000/api
# VITE_API_URL=http://localhost:5000/api

# ALTERNATIVE: Production/Vercel Testing
# To test production configuration locally:
# VITE_API_URL=https://yourdomain.com/api

# Note: For vanilla JS without a bundler, you can also:
# 1. Set localStorage: localStorage.setItem('app_api_base_url', 'http://localhost:3000/api')
# 2. Inject via HTML: window.__APP_CONFIG__ = { API_BASE_URL: 'http://localhost:3000/api' }
# 3. The config.js module will auto-detect localhost and use http://localhost:3000/api
